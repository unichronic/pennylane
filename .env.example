# LLM Providers
MISTRAL_API_KEY=
MISTRAL_API_KEY1=
MISTRAL_API_KEY2=
# For more separate quota pools, prefer comma-separated keys:
MISTRAL_API_KEYS=

# Role-specific LLM settings
LLM_PROVIDER=mistral
# Backward-compatible fallback if the role-specific variables below are unset.
MISTRAL_MODEL=mistral-large-2512
# Speed/quality split: quick roles handle reports, debates, and trader drafts;
# deep roles handle research-manager and portfolio-manager synthesis.
MISTRAL_QUICK_MODEL=mistral-small-2603
MISTRAL_DEEP_MODEL=mistral-large-2512
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Runtime settings
MAX_DEBATE_ROUNDS=1
OUTPUT_LANGUAGE=English
TRADEAGE_DATA_CACHE_DIR=data_cache
TRADEAGE_RESULTS_DIR=results
TRADEAGE_WORKFLOW_DB=data_cache/workflows.db
TRADEAGE_MEMORY_PATH=data_cache/decision_memory.jsonl
TRADEAGE_MEMORY_MAX_ENTRIES=0
TRADEAGE_MEMORY_VECTOR_ENABLED=1
TRADEAGE_MEMORY_VECTOR_PATH=data_cache/decision_memory.vectors.jsonl
TRADEAGE_MEMORY_EMBEDDING_PROVIDER=local
TRADEAGE_MEMORY_EMBEDDING_DIMS=256
MISTRAL_EMBEDDING_MODEL=mistral-embed
TRADEAGE_LLM_TRACE_ENABLED=1
TRADEAGE_LLM_TRACE_PATH=data_cache/llm_calls.jsonl
TRADEAGE_LLM_CALL_TIMEOUT_SECONDS=120
TRADEAGE_LLM_MAX_RETRIES=0
TRADEAGE_LLM_RATE_LIMIT_RETRIES=2
TRADEAGE_LLM_RATE_LIMIT_BACKOFF_SECONDS=30
TRADEAGE_LLM_MAX_TOKENS=2500
TRADEAGE_QUICK_LLM_MAX_TOKENS=2500
TRADEAGE_DEEP_LLM_MAX_TOKENS=4500
TRADEAGE_ANALYST_LLM_MAX_TOKENS=2800
TRADEAGE_DEBATE_LLM_MAX_TOKENS=2800
TRADEAGE_RISK_DEBATE_LLM_MAX_TOKENS=2800
TRADEAGE_TRADER_LLM_MAX_TOKENS=1800
TRADEAGE_RESEARCH_MANAGER_LLM_MAX_TOKENS=4500
TRADEAGE_PORTFOLIO_MANAGER_LLM_MAX_TOKENS=5000
TRADEAGE_PARALLEL_ANALYSTS=1
TRADEAGE_PARALLEL_ANALYST_MAX_WORKERS=0
TRADEAGE_REPORT_CONTEXT_MAX_CHARS=1800
TRADEAGE_INVESTMENT_DEBATE_PROMPT_MAX_CHARS=12000
TRADEAGE_RISK_DEBATE_PROMPT_MAX_CHARS=14000
TRADEAGE_SINGLE_ARGUMENT_PROMPT_MAX_CHARS=6000
TRADEAGE_PLAN_PROMPT_MAX_CHARS=6000
TRADEAGE_CHECKPOINT_ENABLED=1
TRADEAGE_ANALYST_TOOL_MODE=model

# Market data
# auto tries providers in this order. yfinance needs no key; Twelve Data and
# Alpha Vantage are optional free-key fallbacks.
TRADEAGE_DATA_PROVIDER=auto
TRADEAGE_DATA_PROVIDERS=yfinance,twelvedata,alpha_vantage
TRADEAGE_NEWS_VENDOR=yfinance
TRADEAGE_FUNDAMENTALS_VENDOR=yfinance
TRADEAGE_INSIDER_VENDOR=yfinance
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=

# For deterministic offline tests only:
# LLM_PROVIDER=local
